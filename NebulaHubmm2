local function tblMerge(dest, source)
	for k, v in pairs(source) do
		if type(v) == "table" then
			if type(dest[k]) ~= "table" then dest[k] = {} end
			tblMerge(dest[k], v)
		else
			if dest[k] == nil then dest[k] = v end
		end
	end
	return dest
end
local function LoadSettings()
	local s, r = pcall(function() return isfile(SettingsFileName) and readfile(SettingsFileName) end)
	if s and r then
		local d = HttpService:JSONDecode(r)
		if d and d.Config then Config = d.Config; tblMerge(Config, DefaultConfig); return end
	end
	Config = DefaultConfig
end
