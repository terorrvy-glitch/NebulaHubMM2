local function disableCollisionsForVictim(victimChar)
	if not victimChar then return end
	for _, part in pairs(victimChar:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide = false end end
end

local function enableCollisionsForVictim(victimChar)
	if not victimChar then return end
	for _, part in pairs(victimChar:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide = true end end
end

local function attachVictimToKnife(victimChar, knifeHandle)
	if not victimChar or not knifeHandle then return end
	for _, part in pairs(victimChar:GetDescendants()) do if part:IsA("BasePart") then part.CFrame = knifeHandle.CFrame * CFrame.new(0,0,0) end end
end

local knifeAuraActive, knifeAuraRadius, knifeAuraVictims = false, 30, {}

local function startKnifeAura()
	knifeAuraActive = true
	Notify(translate("notify_knife_aura_on"))
	task.spawn(function()
		while knifeAuraActive do
			local has, tool = hasKnife()
			if not has then
				if not equipKnife() then Notify(translate("notify_no_knife")); knifeAuraActive = false; break end
			end
			local handle = tool and (tool:FindFirstChild("Handle") or tool)
			if not handle then task.wait(1) else
				local char = LocalPlayer.Character
				if char then
					local hrp = char:FindFirstChild("HumanoidRootPart")
					if hrp then
						local pos = hrp.Position
						for _, player in pairs(Players:GetPlayers()) do
							if player == LocalPlayer then continue end
							if not player.Character then continue end
							local victimRoot = player.Character:FindFirstChild("HumanoidRootPart")
							if not victimRoot then continue end
							local distance = (victimRoot.Position - pos).Magnitude
							if distance <= knifeAuraRadius then
								if not knifeAuraVictims[player] then
									knifeAuraVictims[player] = true
									disableCollisionsForVictim(player.Character)
									attachVictimToKnife(player.Character, handle)
									task.spawn(function()
										while knifeAuraActive and knifeAuraVictims[player] and player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0 do
											if (player.Character.HumanoidRootPart.Position - pos).Magnitude > knifeAuraRadius then knifeAuraVictims[player] = nil; break end
											swingKnife()
											task.wait(0.3)
										end
										if knifeAuraVictims[player] then knifeAuraVictims[player] = nil end
										if player.Character then enableCollisionsForVictim(player.Character) end
									end)
								else
									attachVictimToKnife(player.Character, handle)
								end
							else
								if knifeAuraVictims[player] then knifeAuraVictims[player] = nil; if player.Character then enableCollisionsForVictim(player.Character) end end
							end
						end
					end
				end
			end
			task.wait(0.2)
		end
		for player, _ in pairs(knifeAuraVictims) do if player and player.Character then enableCollisionsForVictim(player.Character) end end
		knifeAuraVictims = {}
		Notify(translate("notify_knife_aura_off"))
	end)
end

