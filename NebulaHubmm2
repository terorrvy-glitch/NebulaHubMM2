    headerGrad.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, t.AccentLight), ColorSequenceKeypoint.new(1, t.Accent)}
    rightGrad.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, t.MainBg), ColorSequenceKeypoint.new(0.5, t.Panel), ColorSequenceKeypoint.new(1, t.MainBg)}
    for i, tab in ipairs(tabs) do
        local isActive = tab.content.Visible
        tab.button.BackgroundColor3 = isActive and t.Accent or t.Panel
        tab.button.TextColor3 = t.Text
