local activeNotifications = {}
local NOTIFICATION_HEIGHT = 65
local notifyGui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
notifyGui.Name = "NebulaNotifications"
notifyGui.ResetOnSpawn = false

local function updatePositions()
	for i, frame in ipairs(activeNotifications) do
		local targetY = -75 - ((i - 1) * NOTIFICATION_HEIGHT)
		TweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.new(1, -240, 1, targetY)
		}):Play()
	end
end

local function Notify(text)
	local frame = Instance.new("Frame", notifyGui)
	frame.Size = UDim2.new(0, 230, 0, 55)
	frame.Position = UDim2.new(1, 10, 1, -75)
	frame.BackgroundColor3 = GetTheme().NotificationBg
	frame.BackgroundTransparency = 0.1
	frame.BorderSizePixel = 0
	frame.ClipsDescendants = true
	local corner = Instance.new("UICorner", frame); corner.CornerRadius = UDim.new(0, 12)
	local stroke = Instance.new("UIStroke", frame); stroke.Color = GetTheme().Accent; stroke.Thickness = 1.2; stroke.Transparency = 0.4
	local icon = Instance.new("TextLabel", frame)
	icon.Size = UDim2.new(0, 30, 0, 30); icon.Position = UDim2.new(0, 8, 0.5, -15); icon.BackgroundTransparency = 1
	icon.Text = "✦"; icon.TextColor3 = GetTheme().Accent; icon.Font = GetFont(); icon.TextSize = 20
	local label = Instance.new("TextLabel", frame)
	label.Size = UDim2.new(1, -50, 1, -10); label.Position = UDim2.new(0, 45, 0, 5); label.BackgroundTransparency = 1
	label.Text = text; label.TextColor3 = GetTheme().Text; label.Font = GetFont(); label.TextSize = 14; label.TextWrapped = true; label.TextXAlignment = Enum.TextXAlignment.Left
	local progress = Instance.new("Frame", frame)
	progress.Size = UDim2.new(1, 0, 0, 3); progress.Position = UDim2.new(0, 0, 1, -3)
	progress.BackgroundColor3 = GetTheme().Accent; progress.BorderSizePixel = 0
	local progCorner = Instance.new("UICorner", progress); progCorner.CornerRadius = UDim.new(0, 2)
	table.insert(activeNotifications, frame)
	updatePositions()
	local progressTween = TweenService:Create(progress, TweenInfo.new(3, Enum.EasingStyle.Linear), { Size = UDim2.new(0, 0, 0, 3) })
	progressTween:Play()
	task.delay(3, function()
		local tween = TweenService:Create(frame, TweenInfo.new(0.3), {BackgroundTransparency = 1})
		local tweenText = TweenService:Create(label, TweenInfo.new(0.3), {TextTransparency = 1})
		local tweenIcon = TweenService:Create(icon, TweenInfo.new(0.3), {TextTransparency = 1})
		tween:Play(); tweenText:Play(); tweenIcon:Play()
		task.wait(0.3)
		local index = table.find(activeNotifications, frame)
		if index then table.remove(activeNotifications, index); frame:Destroy(); updatePositions() end
	end)
end

