local function getPlayerRole(p)
	if not p.Character then return "Unknown" end
	for _,t in pairs(p.Character:GetChildren()) do
		if t:IsA("Tool") then
			local n = t.Name:lower()
			if n:find("gun") or n:find("pistol") or n:find("sheriff") then return "Sheriff"
			elseif n:find("knife") or n:find("murder") then return "Murderer" end
		end
	end
	local bp = p:FindFirstChild("Backpack")
	if bp then
		for _,t in pairs(bp:GetChildren()) do
