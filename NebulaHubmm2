		local listLayout = Instance.new("UIListLayout", listFrame)
		listLayout.Padding = UDim.new(0, 2)
		listLayout.SortOrder = Enum.SortOrder.LayoutOrder
		listLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center

		local optionHeight = 30
		local function updateListPosition()
			local absPos = headerBtn.AbsolutePosition
			local absSize = headerBtn.AbsoluteSize
			listFrame.Position = UDim2.new(0, absPos.X - mainFrame.AbsolutePosition.X, 0, absPos.Y - mainFrame.AbsolutePosition.Y + absSize.Y)
			listFrame.Size = UDim2.new(0, absSize.X, 0, #options * (optionHeight + 2) + 10)
		end

		local function openList()
			if activeDropdown and activeDropdown ~= listFrame then
				activeDropdown.Visible = false
			end
			listFrame.Visible = true
			activeDropdown = listFrame
			updateListPosition()
		end

		local function closeList()
			listFrame.Visible = false
			if activeDropdown == listFrame then activeDropdown = nil end
		end

		for i, optionName in ipairs(options) do
			local optBtn = Instance.new("TextButton", listFrame)
			optBtn.Size = UDim2.new(1, -10, 0, optionHeight)
			optBtn.BackgroundColor3 = GetTheme().Button
			optBtn.BackgroundTransparency = 0.6
			optBtn.Text = optionName
			optBtn.TextColor3 = GetTheme().Text
			optBtn.Font = GetFont()
			optBtn.TextSize = 14
			optBtn.BorderSizePixel = 0
			optBtn.ZIndex = 1001
			Instance.new("UICorner", optBtn).CornerRadius = UDim.new(0, 6)
			optBtn.MouseButton1Click:Connect(function()
				headerBtn.Text = label .. ": " .. optionName
				closeList()
				callback(optionName)
			end)
		end

		headerBtn.MouseButton1Click:Connect(function()
			if listFrame.Visible then closeList() else openList() end
		end)

		mainFrame.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 and listFrame.Visible then
				local mousePos = UserInputService:GetMouseLocation()
				local listAbsPos = listFrame.AbsolutePosition
				local listAbsSize = listFrame.AbsoluteSize
				local headerAbsPos = headerBtn.AbsolutePosition
				local headerAbsSize = headerBtn.AbsoluteSize
				if not (mousePos.X >= listAbsPos.X and mousePos.X <= listAbsPos.X + listAbsSize.X and mousePos.Y >= listAbsPos.Y and mousePos.Y <= listAbsPos.Y + listAbsSize.Y)
					and not (mousePos.X >= headerAbsPos.X and mousePos.X <= headerAbsPos.X + headerAbsSize.X and mousePos.Y >= headerAbsPos.Y and mousePos.Y <= headerAbsPos.Y + headerAbsSize.Y) then
					closeList()
				end
			end
		end)

		return container
	end

