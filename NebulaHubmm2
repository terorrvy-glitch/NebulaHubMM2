	main.Size = UDim2.new(0,0,0,0)
	task.wait(0.1)
	TweenService:Create(main, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, guiWidth, 0, guiHeight), Position = UDim2.new(0.5, -guiWidth/2, 0.5, -guiHeight/2), BackgroundTransparency = 0.7}):Play()

	-- ===== STRETCH SCREEN =====
	local stretchConnection = nil
	startThread(function()
		while true do
			if Config.Visuals.StretchScreen then
				if not stretchConnection then
					stretchConnection = RunService.RenderStepped:Connect(function()
						if workspace.CurrentCamera then
							local cam = workspace.CurrentCamera
							local amount = Config.Visuals.StretchAmount or 0.75
							cam.CFrame = cam.CFrame * CFrame.new(0, 0, 0, 1, 0, 0, 0, amount, 0, 0, 0, 1)
						end
					end)
				end
			else
				if stretchConnection then stretchConnection:Disconnect(); stretchConnection = nil end
			end
			task.wait(0.5)
		end
	end)

	-- ===== ВИЗУАЛЬНЫЕ ЭФФЕКТЫ =====
	startThread(function() while true do
		if Config.Visuals.TimeChanger then Lighting.TimeOfDay = Config.Visuals.Time..":00:00" end
		if Config.Visuals.ColorCorrection then
			if not Lighting:FindFirstChild("CCEffect") then
				local cc = Instance.new("ColorCorrectionEffect", Lighting); cc.Name = "CCEffect"; cc.Saturation = 0.5; cc.Contrast = 0.5
			end
		else
			local cc = Lighting:FindFirstChild("CCEffect"); if cc then cc:Destroy() end
		end
		if not Config.Visuals.StretchScreen then Camera.FieldOfView = Config.Visuals.FOV or 70 end
		task.wait()
	end end)

	-- ===== АИМБОТ =====
	startThread(function() while true do pcall(function()
		local shouldAim = false
		if Config.Combat.Sheriff.Aimbot.Enabled then
			if IsMobile then shouldAim = true
			else shouldAim = UserInputService:IsKeyDown(Enum.KeyCode.E) end
		end
		if shouldAim then
			local target = nil
			if Config.Combat.Sheriff.TargetMurdererOnly then
				local m = getMurderer()
				if m and m.Character then
					local head = m.Character:FindFirstChild("Head"); local hum = m.Character:FindFirstChild("Humanoid")
					if head and hum and hum.Health > 0 then
						local pos, on = Camera:WorldToViewportPoint(head.Position)
						if on and (Vector2.new(pos.X, pos.Y) - UserInputService:GetMouseLocation()).Magnitude < Config.Combat.Sheriff.Aimbot.FOV then target = {part = head, humanoid = hum} end
					end
				end
			else
				local cd = Config.Combat.Sheriff.Aimbot.FOV
				for _, plr in ipairs(Players:GetPlayers()) do
					if plr ~= LocalPlayer and plr.Character then
						local head = plr.Character:FindFirstChild("Head"); local hum = plr.Character:FindFirstChild("Humanoid")
						if head and hum and hum.Health > 0 then
							local pos, on = Camera:WorldToViewportPoint(head.Position)
							if on then
								local d = (Vector2.new(pos.X, pos.Y) - UserInputService:GetMouseLocation()).Magnitude
								if d < cd then cd = d; target = {part = head, humanoid = hum} end
							end
						end
					end
				end
			end
			if target then
				local moveDir = target.humanoid.MoveDirection
				local vel = (target.humanoid.RootPart and target.humanoid.RootPart.Velocity) or Vector3.zero
				local pred = Config.Combat.Sheriff.Aimbot.Prediction
				local tp = target.part.Position + (vel.Unit * pred * vel.Magnitude) + (moveDir * pred * target.humanoid.WalkSpeed)
				Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, tp), Config.Combat.Sheriff.Aimbot.Smoothness / 25)
			end
		end
	end) RunService.RenderStepped:Wait() end end)

	-- ===== ESP TRACERS =====
	local tracers = {}
	local lastThick = Config.ESP.TracerThickness or 1
	RunService.RenderStepped:Connect(function()
		if Config.ESP.Enabled and Config.ESP.Tracers then
			for _, plr in ipairs(Players:GetPlayers()) do
				if plr ~= LocalPlayer and plr.Character then
					local root = plr.Character:FindFirstChild("HumanoidRootPart")
					if root then
						local pos, on = Camera:WorldToViewportPoint(root.Position)
						if on then
							if not tracers[plr] then tracers[plr] = Drawing.new("Line"); tracers[plr].Thickness = lastThick; tracers[plr].Transparency = 0.8 end
							tracers[plr].Visible = true; tracers[plr].From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y); tracers[plr].To = Vector2.new(pos.X, pos.Y)
							local role = getPlayerRole(plr)
							if role == "Murderer" then tracers[plr].Color = Color3.new(1,0,0) elseif role == "Sheriff" then tracers[plr].Color = Color3.new(0,0.5,1) else tracers[plr].Color = Color3.new(1,1,1) end
						else if tracers[plr] then tracers[plr].Visible = false end end
					end
				end
			end
			for plr, line in pairs(tracers) do if not plr or not plr.Parent or not plr.Character then line:Remove(); tracers[plr] = nil end end
		else for plr, line in pairs(tracers) do line:Remove(); tracers[plr] = nil end end
	end)

	startThread(function() while true do if Config.ESP.ItemESP then for _,v in pairs(workspace:GetDescendants()) do if v.Name == "GunDrop" and v:IsA("BasePart") and not v:FindFirstChild("Highlight") then Instance.new("Highlight", v).FillColor = Color3.fromHSV(tick()%5/5,1,1) end end else for _,v in pairs(workspace:GetDescendants()) do if v:FindFirstChild("Highlight") and v.Name == "GunDrop" then v.Highlight:Destroy() end end end; task.wait(1) end end)

	-- ===== ДВИЖЕНИЕ (ИСПРАВЛЕННЫЙ FLY) =====
	startThread(function() while true do pcall(function()
		if Config.Movement.Fly and LocalPlayer.Character then
			local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
			local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
			if hrp and hum then
				hum.PlatformStand = true
				local spd = Config.Movement.WalkSpeed * Config.Movement.FlySpeed

				local camLook = Camera.CFrame.LookVector
				local flatLook = Vector3.new(camLook.X, 0, camLook.Z).Unit
				if flatLook.Magnitude > 0 then
					hrp.CFrame = CFrame.new(hrp.Position, hrp.Position + flatLook)
				end

				local vel = Vector3.zero
				if UserInputService:IsKeyDown(Enum.KeyCode.W) then vel += Camera.CFrame.LookVector * spd end
				if UserInputService:IsKeyDown(Enum.KeyCode.S) then vel -= Camera.CFrame.LookVector * spd end
				if UserInputService:IsKeyDown(Enum.KeyCode.A) then vel -= Camera.CFrame.RightVector * spd end
				if UserInputService:IsKeyDown(Enum.KeyCode.D) then vel += Camera.CFrame.RightVector * spd end
				if UserInputService:IsKeyDown(Enum.KeyCode.E) then vel += Vector3.new(0, spd, 0) end
				if UserInputService:IsKeyDown(Enum.KeyCode.Q) then vel -= Vector3.new(0, spd, 0) end
				if not UserInputService:IsKeyDown(Enum.KeyCode.E) and not UserInputService:IsKeyDown(Enum.KeyCode.Q) then
					vel = Vector3.new(vel.X, 0, vel.Z)
				end
				hrp.Velocity = vel
			end
		elseif LocalPlayer.Character then
			local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
			if hum and hum.PlatformStand then hum.PlatformStand = false end
		end
	end) RunService.Heartbeat:Wait() end end)

	startThread(function() while true do pcall(function() if Config.Movement.Noclip and LocalPlayer.Character then for _, p in ipairs(LocalPlayer.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end end end) RunService.Stepped:Wait() end end)
	startThread(function() while true do pcall(function() if Config.Movement.BHop and LocalPlayer.Character then local hum = LocalPlayer.Character:FindFirstChild("Humanoid"); if hum and hum.MoveDirection.Magnitude > 0 and hum.FloorMaterial ~= Enum.Material.Air then hum:ChangeState(Enum.HumanoidStateType.Jumping) end end end) task.wait(0.05) end end)

	LocalPlayer.CharacterAdded:Connect(function(char)
		local hum = char:WaitForChild("Humanoid", 5)
		if hum then
			if Config.Movement.CustomWalkSpeed then hum.WalkSpeed = Config.Movement.WalkSpeed end
			if Config.Movement.CustomJumpPower then hum.JumpPower = Config.Movement.JumpPower end
		end
	end)

	-- ===== ANTI FLING =====
	startThread(function()
		while true do
			if Config.Movement.AntiFling then
				for _, plr in ipairs(Players:GetPlayers()) do
					if plr ~= LocalPlayer and plr.Character then
						for _, part in ipairs(plr.Character:GetDescendants()) do
							if part:IsA("BasePart") then part.CanCollide = false end
						end
					end
				end
			end
			task.wait(0.5)
		end
	end)

	Players.PlayerAdded:Connect(function(plr)
		plr.CharacterAdded:Connect(function(char)
			if Config.Movement.AntiFling then
				task.wait(0.1)
				for _, part in ipairs(char:GetDescendants()) do
					if part:IsA("BasePart") then part.CanCollide = false end
				end
			end
		end)
	end)

	-- ===== УМНЫЙ ФАРМ + KILL MODE + XP FARM (ТОЧНЫЙ ТРЕКИНГ ЧЕРЕЗ COINCOLLECTED) =====
	local farmPaused = false
	local xpFarmPaused = false
	local Gameplay = game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("Gameplay")
	local CoinCollectedRemote = Gameplay:WaitForChild("CoinCollected")

	local sessionCoinsCollected = 0
	local sessionStartTime = tick()
	local roundCoinsCollected = 0

	startThread(function()
		while true do
			if Config.Farm.AutoFarm and not Config.Farm.AutoPauseFarm then farmPaused = false end
			task.wait(1)
		end
	end)

	Gameplay.GameOver.OnClientEvent:Connect(function()
		if Config.Farm.AutoFarm and Config.Farm.AutoPauseFarm then farmPaused = true; Notify(translate("notify_farm_paused")) end
	end)
	Gameplay.RoundEndFade.OnClientEvent:Connect(function()
		if Config.Farm.AutoFarm and Config.Farm.AutoPauseFarm then farmPaused = true; Notify(translate("notify_farm_paused")) end
	end)

	Gameplay.RoundStart.OnClientEvent:Connect(function()
		if Config.Farm.AutoFarm and Config.Farm.AutoPauseFarm then
			farmPaused = false; xpFarmPaused = false; roundCoinsCollected = 0; Notify(translate("notify_farm_resumed"))
		end
	end)
	Gameplay.ShowRoleSelect.OnClientEvent:Connect(function()
		if Config.Farm.AutoFarm and Config.Farm.AutoPauseFarm then
			farmPaused = false; xpFarmPaused = false; roundCoinsCollected = 0; Notify(translate("notify_farm_resumed"))
		end
	end)
	Gameplay.CoinsStarted.OnClientEvent:Connect(function()
		if Config.Farm.AutoFarm and Config.Farm.AutoPauseFarm then
			farmPaused = false; xpFarmPaused = false; roundCoinsCollected = 0; Notify(translate("notify_farm_resumed"))
		end
	end)

	CoinCollectedRemote.OnClientEvent:Connect(function(bagName, coinCount, maxCoins)
		roundCoinsCollected = roundCoinsCollected + 1
		sessionCoinsCollected = sessionCoinsCollected + 1
		if coinCount >= maxCoins then
			if Config.Farm.XPFarm then
				local char = LocalPlayer.Character
				if char and char:FindFirstChild("HumanoidRootPart") then
					if getPlayerRole(LocalPlayer) == "Murderer" then
						killAllInstant()
						char.HumanoidRootPart.CFrame = CFrame.new(14, 505, -13)
						xpFarmPaused = true
						Notify(translate("notify_xp_farm_murderer"))
					else
						char.HumanoidRootPart.CFrame = CFrame.new(14, 505, -13)
						xpFarmPaused = true
						Notify(translate("notify_xp_farm_innocent"))
					end
				end
			elseif Config.Farm.AutoKillAll and getPlayerRole(LocalPlayer) == "Murderer" then
				Notify(translate("notify_backpack_full"))
				killAllInstant()
			elseif Config.Farm.FlingMurderer and getPlayerRole(LocalPlayer) ~= "Murderer" then
				local murderer = getMurderer()
				if murderer and murderer.Character and murderer.Character:FindFirstChildOfClass("Humanoid") and
					murderer.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
					Notify(translate("notify_backpack_full"))
					flingSinglePlayer(murderer)
				end
			end
		end
	end)

	local function isCoinVisible(coin)
		if not coin:FindFirstChild("TouchInterest") then return false end
		local coinVisual = coin:FindFirstChild("CoinVisual")
		if coinVisual then
			local mainCoin = coinVisual:FindFirstChild("MainCoin")
			if mainCoin and mainCoin:IsA("BasePart") and mainCoin.Transparency == 0 then return true end
		end
		return false
	end

	local function flyToCoinAndCollect(coin)
		local char = LocalPlayer.Character
		if not char then return false end
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if not hrp then return false end
		local hum = char:FindFirstChildOfClass("Humanoid")
		if not hum then return false end

		hum.PlatformStand = true
		for _, v in ipairs(hrp:GetChildren()) do
			if v:IsA("BodyVelocity") or v:IsA("BodyGyro") then v:Destroy() end
		end

		local bv = Instance.new("BodyVelocity")
		bv.MaxForce = Vector3.new(1e6, 1e6, 1e6)
		bv.Velocity = Vector3.zero
		bv.P = 10000
		bv.Parent = hrp

		local bg = Instance.new("BodyGyro")
		bg.MaxTorque = Vector3.new(1e6, 1e6, 1e6)
		bg.P = 10000
		bg.CFrame = hrp.CFrame
		bg.Parent = hrp

		local coinPos = coin.Position
		local moveSpeed = Config.Farm.FarmSpeed or 200
		local targetPos = Vector3.new(coinPos.X, math.max(coinPos.Y - 5, 5), coinPos.Z)
		local startTime = tick()

		while tick() - startTime < 1.5 do
			if not Config.Farm.AutoFarm or farmPaused then break end
			if not isCoinVisible(coin) then break end
			local direction = targetPos - hrp.Position
			if direction.Magnitude < 5 then break end
			bv.Velocity = direction.Unit * moveSpeed
			task.wait()
		end

		if isCoinVisible(coin) then
			local originalPos = coin.Position
			coin.CFrame = hrp.CFrame * CFrame.new(0, 3, 0)
			firetouchinterest(hrp, coin, 0)
			firetouchinterest(hrp, coin, 1)
			task.wait(0.05)
			if not isCoinVisible(coin) then
				-- монета подобрана
			else
				coin.CFrame = CFrame.new(originalPos)
			end
		end

		bv:Destroy()
		bg:Destroy()
		hum.PlatformStand = false
		for _, v in ipairs(hrp:GetChildren()) do
			if v:IsA("BodyVelocity") or v:IsA("BodyGyro") then v:Destroy() end
		end
		return true
	end

	LocalPlayer.CharacterAdded:Connect(function(char)
		local hum = char:WaitForChild("Humanoid", 5)
		if hum then
			hum.Died:Connect(function()
				if Config.Farm.FlingMurderer and not Config.Farm.XPFarm then
					local murderer = getMurderer()
					if murderer and murderer.Character and murderer.Character:FindFirstChildOfClass("Humanoid") and
						murderer.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
						flingSinglePlayer(murderer)
					end
				end
			end)
		end
	end)

	startThread(function()
		while true do
			pcall(function()
				if Config.Farm.AutoFarm and not farmPaused and not flingInProgress and not xpFarmPaused then
					local char = LocalPlayer.Character
					local hrp = char and char:FindFirstChild("HumanoidRootPart")
					if hrp then
						local container = workspace:FindFirstChild("CoinContainer", true)
						if container then
							local bestCoin = nil
							local bestDist = math.huge
							for _, coin in pairs(container:GetChildren()) do
								if coin:IsA("BasePart") and isCoinVisible(coin) then
									local dist = (hrp.Position - coin.Position).Magnitude
									if dist < bestDist and dist <= Config.Farm.FarmRadius then
										bestDist = dist
										bestCoin = coin
									end
								end
							end
							if bestCoin then
								flyToCoinAndCollect(bestCoin)
							end
						end
						if not flingInProgress then
							for _, v in ipairs(hrp:GetChildren()) do
								if v:IsA("BodyVelocity") or v:IsA("BodyGyro") then v:Destroy() end
							end
						end
					end
				end
			end)
			task.wait(0.05)
		end
	end)

	local coinsLabel = farmContent and farmContent:FindFirstChild("CoinsLabel") or nil  -- устанавливается при создании GUI

	startThread(function()
		while true do
			local hoursPassed = (tick() - sessionStartTime) / 3600
			local perHour = hoursPassed > 0 and math.floor(sessionCoinsCollected / hoursPassed) or 0
			if coinsLabel then
				coinsLabel.Text = translate("label_coins_collected")..": "..sessionCoinsCollected.." | "..translate("label_coins_per_hour")..": "..perHour
			end
			task.wait(0.5)
		end
	end)

	-- AutoSheriff
	startThread(function()
		while true do
			pcall(function()
				if Config.Farm.AutoSheriff then
					local char = LocalPlayer.Character
					if char and char:FindFirstChild("HumanoidRootPart") then
						local droppedGun = workspace:FindFirstChild("GunDrop", true)
						if droppedGun and droppedGun:IsA("BasePart") then
							droppedGun.CFrame = char.HumanoidRootPart.CFrame
							firetouchinterest(char.HumanoidRootPart, droppedGun, 0)
							firetouchinterest(char.HumanoidRootPart, droppedGun, 1)
						end
					end
				end
			end)
			task.wait(0.7)
		end
	end)

	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if input.KeyCode == Enum.KeyCode.T and not gameProcessed and not IsMobile then
			if getPlayerRole(LocalPlayer) == "Murderer" then killAllInstant() else Notify("❌ Вы не убийца!") end
		end
	end)

	local fpsCounter, fpsTimer = 0, tick()
	task.spawn(function()
		while true do
			fpsCounter = fpsCounter + 1
			if tick() - fpsTimer >= 0.5 then
				local fps = math.floor(fpsCounter / (tick() - fpsTimer))
				local ping = 0
				pcall(function() ping = LocalPlayer:GetNetworkPing() * 1000 end)
				if fpsPingLabel then
					fpsPingLabel.Text = translate("label_fps")..": "..fps.." | "..translate("label_ping")..": "..math.floor(ping).." ms"
				end
				fpsCounter = 0; fpsTimer = tick()
			end
			RunService.RenderStepped:Wait()
		end
	end)

	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if IsMobile then return end
		if input.KeyCode == Enum.KeyCode.RightShift then main.Visible = not main.Visible; return end
		if not main.Visible or gameProcessed then return end
		if input.KeyCode == Enum.KeyCode.F then Config.Movement.Fly = not Config.Movement.Fly; Notify(translate("notify_fly").." "..(Config.Movement.Fly and "вкл" or "выкл")) end
		if input.KeyCode == Enum.KeyCode.X then Config.Movement.Noclip = not Config.Movement.Noclip; Notify(translate("notify_noclip").." "..(Config.Movement.Noclip and "вкл" or "выкл")) end
		if input.KeyCode == Enum.KeyCode.V then Config.ESP.Enabled = not Config.ESP.Enabled; Notify(translate("notify_esp").." "..(Config.ESP.Enabled and "вкл" or "выкл")) end
	end)

	Players.PlayerRemoving:Connect(function(player)
		if player == LocalPlayer then SaveSettings() end
	end)
end

ShowKeyWindow()
