local function killAllInstant()
	local char = LocalPlayer.Character
	if not char then Notify(translate("notify_no_knife")); return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	local knifeEquipped = false
	for attempt = 1, 5 do
		local has, tool = hasKnife()
		if has then
			if tool.Parent ~= char then
				tool.Parent = char; task.wait(0.3)
				if tool:IsA("Tool") then tool:Activate(); task.wait(0.1) end
			end
			local handTool = char:FindFirstChildOfClass("Tool")
			if handTool and (handTool.Name:lower():find("knife") or handTool.Name:lower():find("murder")) then
				knifeEquipped = true; break
			end
		else equipKnifeImproved() end
		task.wait(0.2)
	end
	if not knifeEquipped then Notify("❌ Не удалось достать нож!"); return end
	local allPlayers = {}
	for _, player in pairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then table.insert(allPlayers, player) end
	end
	if #allPlayers == 0 then Notify(translate("notify_no_players")); return end
	local startTime = tick()
	local maxDuration = 3
	task.spawn(function()
		while tick() - startTime < maxDuration do
			for _, player in ipairs(allPlayers) do
				pcall(function()
					if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
						player.Character.HumanoidRootPart.CFrame = hrp.CFrame * CFrame.new(math.random(-2, 2), 0, -3)
					end
				end)
			end
			pcall(function() swingKnifeImproved() end)
			task.wait(0.03)
		end
	end)
	task.wait(maxDuration + 0.5)
	Notify("Убить всех выполнено! " .. #allPlayers .. " игроков.")
end

