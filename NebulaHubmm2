local function translate(key, ...)
	local lang = Config.Language or "ru"
	local str = L[lang] and L[lang][key] or key
	if not str then return key end
	local args = {...}
	for i, v in ipairs(args) do str = string.gsub(str, "{"..tostring(i-1).."}", tostring(v)) end
	return str
end

